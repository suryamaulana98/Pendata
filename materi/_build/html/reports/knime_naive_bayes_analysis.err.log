# ================================
# IMPORT LIBRARY
# ================================

import knime.scripting.io as knio   # Untuk komunikasi data antara KNIME dan Python
import pandas as pd               # Untuk manipulasi data dalam bentuk tabel (DataFrame)
from sklearn.naive_bayes import GaussianNB  # Model Gaussian Naive Bayes
from sklearn.metrics import accuracy_score  # Untuk evaluasi akurasi model


# ================================
# LOAD DATA DARI KNIME
# ================================

# Mengambil data training (80%) dari KNIME
df_train = knio.input_tables[0].to_pandas()

# Mengambil data testing (20%) dari KNIME
df_test = knio.input_tables[1].to_pandas()


# ================================
# MENENTUKAN TARGET (LABEL)
# ================================

# Kolom 'risk' adalah target yang ingin diprediksi (Good / Bad)
target_col = "risk"


# ================================
# MEMISAHKAN FITUR DAN TARGET
# ================================

# X_train → semua kolom selain target (sebagai fitur)
# select_dtypes(include=['number']) → hanya ambil kolom numerik
# (karena GaussianNB hanya bisa memproses angka)
X_train = df_train.drop(columns=[target_col]).select_dtypes(include=['number'])

# y_train → kolom target (risk)
y_train = df_train[target_col]


# Untuk data testing (proses yang sama)
X_test = df_test.drop(columns=[target_col]).select_dtypes(include=['number'])
y_test = df_test[target_col]


# ================================
# MEMBUAT MODEL NAIVE BAYES
# ================================

# Inisialisasi model Gaussian Naive Bayes
model = GaussianNB()


# ================================
# TRAINING MODEL
# ================================

# Model belajar dari data training (mencari pola antara fitur dan target)
model.fit(X_train, y_train)


# ================================
# PREDIKSI DATA TESTING
# ================================

# Model digunakan untuk memprediksi data yang belum pernah dilihat (data testing)
y_pred = model.predict(X_test)


# ================================
# EVALUASI MODEL
# ================================

# Menghitung akurasi: seberapa banyak prediksi yang benar
acc = accuracy_score(y_test, y_pred)

# Menampilkan hasil akurasi di console KNIME
print(f"Accuracy: {acc:.4f} ({acc*100:.2f}%)")


# ================================
# MENYIMPAN HASIL PREDIKSI
# ================================

# Menambahkan kolom baru "Prediction" ke data testing
df_test["Prediction"] = y_pred


# ================================
# OUTPUT KE KNIME
# ================================

# Mengirim kembali hasil ke KNIME agar bisa diproses oleh node berikutnya (Scorer)
knio.output_tables[0] = knio.Table.from_pandas(df_test)
